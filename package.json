{
  "name": "simple-nominatim",
  "description": "Monorepo for Simple Nominatim packages",
  "version": "0.0.0",
  "author": "Jonathan Linat (https://github.com/jonathanlinat)",
  "bugs": "https://github.com/jonathanlinat/simple-nominatim/issues",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/format": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-yml": "^3.3.1",
    "execa": "^9.6.1",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "syncpack": "^14.3.0",
    "tsdown": "^0.21.10",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "bun": "please-use-pnpm",
    "deno": "please-use-pnpm",
    "node": "24.10.0",
    "npm": "please-use-pnpm",
    "pnpm": "10.18.3",
    "yarn": "please-use-pnpm"
  },
  "homepage": "https://github.com/jonathanlinat/simple-nominatim#readme",
  "license": "MIT",
  "packageManager": "pnpm@10.18.3",
  "private": true,
  "repository": "jonathanlinat/simple-nominatim.git",
  "scripts": {
    "ci:release": "changeset publish",
    "ci:version": "changeset version",
    "clean": "turbo run clean && rm -rf node_modules",
    "deps:check": "syncpack lint",
    "deps:fix": "syncpack fix-mismatches",
    "deps:format": "syncpack format",
    "deps:list": "syncpack list",
    "deps:update": "syncpack update",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "packages:build": "turbo run build",
    "packages:build:watch": "turbo run build --watch",
    "postinstall": "pnpm simple-git-hooks",
    "prepublishOnly": "pnpm packages:build && pnpm test",
    "security:audit": "pnpm audit --prod --audit-level=high",
    "security:audit:fix": "pnpm audit --fix",
    "security:audit:full": "pnpm audit --audit-level=moderate",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run packages/*/src/__tests__/**/*.e2e.test.ts",
    "test:unit": "vitest run packages/*/src/__tests__/**/*.unit.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
